---
import AppShell from "../layouts/AppShell.astro";
import { AvContainer, AvButton } from "@ansiversa/components";
import { APP_DESCRIPTION, APP_NAME } from "../app.meta";

const title = `${APP_NAME} – Ansiversa`;
const description = APP_DESCRIPTION;
---

<AppShell title={title} description={description}>
  <!-- Hero -->
  <section class="av-hero">
    <AvContainer size="narrow" className="av-hero__content--narrow">
      <div class="av-hero__content">
        <div class="av-kicker">
          <span>Career & Work · Ansiversa Mini App</span>
        </div>
        <h1 class="av-gradient-text">{APP_NAME}</h1>
        <p>
          {APP_DESCRIPTION}
        </p>
      </div>
      <div class="av-cta-row">
        <AvButton href="/app">Open app</AvButton>
      </div>
    </AvContainer>
  </section>

  <!-- Problem -->
  <section class="av-section">
    <AvContainer size="narrow">
      <div class="av-section-header">
        <h2 class="av-section-title">The problem it solves</h2>
        <p class="av-section-lead">
          Career tasks like resumes, meetings, and communication often feel scattered.
        </p>
      </div>
      <div class="av-section-body space-y-3 text-slate-300">
        <p>Email Polisher gives you a clean workspace to draft and refine business emails quickly.</p>
      </div>
    </AvContainer>
  </section>

  <!-- Why this mini app -->
  <section class="av-section">
    <AvContainer size="narrow">
      <div class="av-section-header">
        <h2 class="av-section-title">Why Email Polisher feels different</h2>
        <p class="av-section-lead">
          A focused mini app inside the larger Ansiversa ecosystem.
        </p>
      </div>
      <div class="av-section-body">
        <ul class="space-y-2 text-slate-300 list-disc list-inside">
          <li>Focused on a single, real-world career task.</li>
          <li>Gives you professional-quality output without complex tools.</li>
          <li>Keeps everything structured, consistent, and reusable.</li>
        </ul>
      </div>
    </AvContainer>
  </section>

  <!-- How it works -->
  <section class="av-section">
    <AvContainer size="narrow">
      <div class="av-section-header">
        <h2 class="av-section-title">How it works</h2>
        <p class="av-section-lead">
          Simple, clear steps so people can start in under a minute.
        </p>
      </div>
      <ol class="av-section-body space-y-2 text-slate-300 list-decimal list-inside">
          <li>Enter subject, recipients, tone, and context.</li>
          <li>Draft and compare three polished variants.</li>
          <li>Copy your preferred draft instantly.</li>
      </ol>
    </AvContainer>
  </section>

  <!-- Final CTA -->
  <section class="av-section">
    <AvContainer size="narrow">
      <div class="av-section-header">
        <h2 class="av-section-title">Ready to polish your next email?</h2>
        <p class="av-section-lead">
          Open the app, refine your message with structure, and send with confidence.
        </p>
      </div>
      <div class="av-cta-row">
        <AvButton href="/app">Start in /app</AvButton>
      </div>
    </AvContainer>
  </section>
</AppShell>
